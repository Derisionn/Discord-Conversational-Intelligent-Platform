# ─── Discord ──────────────────────────────────────────────────────────────────
# Get this from: https://discord.com/developers/applications
# → Your App → Bot → Token (Reset Token if needed)
DISCORD_TOKEN=your_discord_bot_token_here

# Right-click your server name → Copy Server ID (enable Developer Mode first)
DISCORD_GUILD_ID=your_guild_id_here

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxx.mongodb.net/
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=discord_intel

# ─── History Fetcher ──────────────────────────────────────────────────────────
# Max messages to fetch per channel (set to 0 for ALL, be careful with large servers)
HISTORY_LIMIT=5000
